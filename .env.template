# ============================================================
# printer-v2 — Environment Variable Template
# Copy this file to .env and fill in all required values.
# Never commit .env to version control.
# ============================================================

# ---- Kalshi API (REQUIRED) ---------------------------------
KALSHI_API_KEY_ID=               # Your Kalshi API key ID (UUID)
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem  # Path to RSA private key file
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2  # Use demo URL for paper trading

# ---- Coinbase Advanced Trade (REQUIRED) --------------------
COINBASE_API_KEY=                # Coinbase API key
COINBASE_API_SECRET=             # Coinbase API secret

# ---- Ensemble Engine ---------------------------------------
ENSEMBLE_CONFIDENCE_MIN=0.60     # Minimum confidence to trigger a trade [0.0–1.0]
MODEL_WEIGHT_TREND=0.30          # Initial weight for trend-following model
MODEL_WEIGHT_MEAN_REV=0.25       # Initial weight for mean-reversion model
MODEL_WEIGHT_MOMENTUM=0.25       # Initial weight for momentum model
MODEL_WEIGHT_VOL=0.20            # Initial weight for volatility-regime model

# ---- Risk Gates --------------------------------------------
MAX_DAILY_DRAWDOWN_PCT=0.05      # Gate 1: halt if daily loss exceeds X% of balance
MAX_POSITION_EXPOSURE=0.20       # Gate 2: max total open exposure as fraction of balance
MIN_MINUTES_BETWEEN_TRADES=15    # Gate 5: cooldown between trades (minutes)
MAX_BTC_VOL_THRESHOLD=0.04       # Gate 4: halt if 1h realized BTC vol exceeds X

# ---- Kelly Sizing ------------------------------------------
KELLY_FRACTION=0.5               # Fractional Kelly multiplier (0.5 = half-Kelly)
MAX_POSITION_PCT=0.10            # Hard cap: max single position as fraction of balance

# ---- Telegram Alerts (optional) ----------------------------
TELEGRAM_TOKEN=                  # Bot token from @BotFather
TELEGRAM_CHAT_ID=                # Your chat or group ID

# ---- Web Dashboard -----------------------------------------
DASHBOARD_PASSWORD=changeme      # HTTP Basic Auth password for dashboard
PORT=5000                        # Port for Flask/Gunicorn (Railway sets this automatically)

# ---- Database ----------------------------------------------
DATABASE_PATH=printer_v2.db      # SQLite file path (relative to project root)
