# ============================================================
# printer-v2 — Environment Variable Template
# cp .env.template .env   then fill in every required value.
# Never commit .env to version control.
# ============================================================

# === KALSHI ===
KALSHI_API_KEY=                          # UUID from Kalshi API settings
KALSHI_PRIVATE_KEY=kalshi_private_key.pem  # file path OR raw PEM string
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2
KALSHI_DEMO=false                        # true = paper trading / demo

# === AI MODELS ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# === AI MODEL IDs (defaults shown) ===
CLAUDE_MODEL=claude-sonnet-4-5
GPT_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash
DEEPSEEK_MODEL=deepseek-reasoner

# === ENSEMBLE WEIGHTS (auto-normalised to sum 1.0) ===
CLAUDE_WEIGHT=0.30
GPT_WEIGHT=0.25
GEMINI_WEIGHT=0.25
DEEPSEEK_WEIGHT=0.20

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=                      # from @BotFather on Telegram
TELEGRAM_CHAT_ID=                        # your personal or group chat ID

# === TRADING ===
MAX_BET_SIZE=25.0                        # max dollars per trade
DAILY_LOSS_LIMIT=100.0                   # halt after losing this much today
MAX_OPEN_POSITIONS=3                     # max concurrent open trades
KELLY_FRACTION=0.5                       # 0.5 = half-Kelly sizing
MIN_EDGE=0.05                            # minimum 5% edge required
MIN_CONFIDENCE=0.55                      # minimum ensemble confidence [0–1]
MAX_MODEL_SPREAD=0.35                    # max disagreement between models
STOP_LOSS_PCT=0.15                       # close at −15% of cost basis
CONFIDENCE_DECAY_EXIT=0.40              # exit if market bid drops below 40¢

# === COINBASE FEED ===
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com
BTC_PRODUCT_ID=BTC-USD
PRICE_STALENESS_SECONDS=30

# === DATABASE ===
DB_PATH=printer_v2.db

# === DASHBOARD ===
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
