# ============================================================
# printer-v2 — Environment Variable Template
# Copy this file to .env and fill in all required values.
# Never commit .env to version control.
# ============================================================

# ---- Trading (REQUIRED defaults are fine for most users) ---
MAX_BET_SIZE=25.0              # Max dollars per trade
DAILY_LOSS_LIMIT=100.0         # Halt trading after losing this much today
KELLY_FRACTION=0.5             # Fractional Kelly (0.5 = half-Kelly)
MIN_EDGE=0.05                  # Minimum 5% edge required to place a trade
MIN_CONFIDENCE=0.55            # Minimum ensemble confidence score [0–1]
MAX_MODEL_SPREAD=0.35          # Abort if model disagreement exceeds this
MAX_OPEN_POSITIONS=3           # Maximum concurrent open positions
STOP_LOSS_PCT=0.15             # Close position at -15% of cost
CONFIDENCE_DECAY_EXIT=0.40     # Exit open position if confidence drops here

# ---- Kalshi (REQUIRED) -------------------------------------
KALSHI_API_KEY=                # Your Kalshi API key ID (UUID)
KALSHI_PRIVATE_KEY=./kalshi_private_key.pem  # File path OR raw PEM string
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2
KALSHI_DEMO=false              # Set to true to use demo environment

# ---- Coinbase WebSocket ------------------------------------
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com
BTC_PRODUCT_ID=BTC-USD
PRICE_STALENESS_SECONDS=30

# ---- AI Model API Keys (REQUIRED) -------------------------
ANTHROPIC_API_KEY=             # console.anthropic.com
OPENAI_API_KEY=                # platform.openai.com
GEMINI_API_KEY=                # aistudio.google.com
DEEPSEEK_API_KEY=              # platform.deepseek.com

# ---- AI Model IDs ------------------------------------------
CLAUDE_MODEL=claude-sonnet-4-5
GPT_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash
DEEPSEEK_MODEL=deepseek-reasoner

# ---- Ensemble Weights (auto-normalized if they don't sum to 1.0) ---
CLAUDE_WEIGHT=0.30
GPT_WEIGHT=0.25
GEMINI_WEIGHT=0.25
DEEPSEEK_WEIGHT=0.20

# ---- Telegram Alerts (optional — leave blank to disable) ---
TELEGRAM_BOT_TOKEN=            # From @BotFather
TELEGRAM_CHAT_ID=              # Your chat or group ID

# ---- Database ----------------------------------------------
DB_PATH=printer_v2.db

# ---- Dashboard ---------------------------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_PASSWORD=changeme    # HTTP Basic Auth password
